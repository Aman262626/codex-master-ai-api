# ============================================================
# CodeX Master AI API - Environment Variables
# ============================================================

# ---- REQUIRED: At least one provider key ----

# OpenRouter (Recommended - gives access to 100+ models)
# Get FREE key at: https://openrouter.ai
# Free models included: Llama 3.3, Gemini Flash, DeepSeek R1, Mistral, Qwen 2.5
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxx

# Groq (FASTEST - LPU inference, completely free tier)
# Get FREE key at: https://console.groq.com
# Gives: Llama 3.3, Mixtral, Gemma at ~1200 tok/sec
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxx

# Google AI Studio (Gemini - Free tier)
# Get FREE key at: https://aistudio.google.com/app/apikey
# Gives: Gemini 2.0 Flash, Gemini 1.5 Pro (1M/2M context), Vision
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxx

# ---- OPTIONAL ----

# Require API key authentication (set to true in production)
REQUIRE_AUTH=false

# Your deployed URL (used in OpenRouter HTTP-Referer)
SITE_URL=https://codex-master-api.onrender.com

# Port (auto-set on Render)
# PORT=8000
